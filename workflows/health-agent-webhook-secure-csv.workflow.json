      ]
    },
    {
      "parameters": {
        "jsCode": "return [{\n  json: {\n    ok: true,\n    telegram_sent: false,\n    alert_count: $json.alert_count,\n    alerts: $json.alerts,\n    payload: $json.payload,\n    csv_path: $json.csv_path,\n    received_at: $json.received_at,\n  },\n}];"
      },
      "id": "7a0d8ce2-95c4-4d23-9f6d-3ed32c4f1015",
