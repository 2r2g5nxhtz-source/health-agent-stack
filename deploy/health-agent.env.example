TZ=UTC

# Public base URL of your n8n instance
N8N_BASE_URL=https://n8n.example.com

# Full incoming webhook URL that the iPhone app should call
HEALTH_AGENT_WEBHOOK_URL=https://n8n.example.com/webhook/apple-health

# Optional downstream alerting
TELEGRAM_BOT_TOKEN=123456:ABCDEF
TELEGRAM_CHAT_ID=123456789

# Optional local AI
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional CSV log path used by your automations
HEALTH_AGENT_CSV_PATH=/data/health-agent/health-log.csv
