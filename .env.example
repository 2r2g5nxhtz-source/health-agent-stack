# Core database
AI_MARKET_RADAR_DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_market_radar

# LLM provider
AI_MARKET_RADAR_LLM_API_KEY=replace_me
AI_MARKET_RADAR_LLM_MODEL=replace_me
AI_MARKET_RADAR_LLM_BASE_URL=https://api.openai.com/v1

# Optional cost accounting
AI_MARKET_RADAR_LLM_INPUT_PRICE_PER_1K=0
AI_MARKET_RADAR_LLM_OUTPUT_PRICE_PER_1K=0

# Telegram delivery
AI_MARKET_RADAR_TELEGRAM_BOT_TOKEN=replace_me
AI_MARKET_RADAR_TELEGRAM_CHAT_ID=replace_me

# Optional runtime toggles
AI_MARKET_RADAR_ENV=development
AI_MARKET_RADAR_LOG_LEVEL=INFO
